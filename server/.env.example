# Copy this file to ".env" and fill in your key to enable the AI features.
# Without a key, the app still runs fully using deterministic fallbacks.

# Get a key at https://openrouter.ai/keys  (free-tier models are available)
OPENROUTER_API_KEY=

# Optional: any model slug OpenRouter supports. Defaults to openai/gpt-4o-mini.
# Free options include: meta-llama/llama-3.1-8b-instruct:free
OPENROUTER_MODEL=openai/gpt-4o-mini

# Optional: change the API port (defaults to 3001)
# PORT=3001
